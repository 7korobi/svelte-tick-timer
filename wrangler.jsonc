{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "svelte-tick-timer",
  "compatibility_date": "2026-07-05",
  "compatibility_flags": ["nodejs_compat"],
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "observability": {
    "enabled": true
  }
}
