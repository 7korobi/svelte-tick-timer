	"homepage": "https://github.com/7korobi/svelte-tick-timer/blob/main/src/lib/",
	"license": "MIT",
	"keywords": [
		"svelte",
		"component",
		"timer",
		"fancy-date",
		"calendar"
	],
	"author": {
		"name": "7korobi",
		"email": "7korobi@gmail.com"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"deploy": "svelte-kit sync && svelte-package",
		"publish:npm": "cd package && npm publish",
		"publish": "run-s format deploy publish:npm",
		"test": "playwright test",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --plugin-search-dir . --check .",
		"format": "prettier --plugin-search-dir . --write ."
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"vite": "^7.3.6"
	},
	"dependencies": {
		"fancy-date": "^0.5.0",
		"tslib": "^2.8.1"
	},
	"exports": {
		"./package.json": "./package.json",
		".": "./index.js",
		"./tick.svelte": "./tick.svelte.js",
		"./distance.svelte": "./distance.svelte.js",
		"./time.svelte": "./time.svelte"
	},
	"svelte": "./index.js"
}
